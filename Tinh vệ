local function AI_IsQuestClaimed(slot)
    for _, obj in pairs(slot:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            if string.find(string.lower(obj.Text), "claimed") then
                return true
            end
        end
        if string.find(string.lower(obj.Name), "claimed") then
            return true
        end
    end
    return false
end

local function AI_GetActionButton(slot, keyword)
    for _, obj in pairs(slot:GetDescendants()) do
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and obj.Visible then
            local name = string.lower(obj.Name)
            local text = string.lower(obj:IsA("TextButton") and obj.Text or "")
            
            if keyword == "claim" and (string.find(name, "claimed") or string.find(text, "claimed")) then
                continue
            end
            
            if string.find(name, keyword) or string.find(text, keyword) then
                return obj
            end
            
            for _, child in pairs(obj:GetChildren()) do
                if child:IsA("TextLabel") then
                    local cText = string.lower(child.Text)
                    local cName = string.lower(child.Name)
                    
                    if keyword == "claim" and (string.find(cText, "claimed") or string.find(cName, "claimed")) then
                        continue
                    end
                    
                    if string.find(cText, keyword) or string.find(cName, keyword) then
                        return obj
                    end
                end
            end
        end
    end
    return nil
end

local function AI_IsQuestCompletedByText(slot)
    for _, obj in pairs(slot:GetDescendants()) do
        if obj:IsA("TextLabel") then
            local current, max = string.match(obj.Text, "(%d+)/(%d+)")
            if current and max then
                if tonumber(current) >= tonumber(max) and tonumber(max) > 0 then
                    return true
                end
            end
            local txt = string.lower(obj.Text)
            if txt == "completed" or txt == "done" or txt == "finished" then
                return true
            end
        end
    end
    return false
end

local function AI_ParseQuestText(text)
    local plantAmt, plantName = string.match(text, "Plant (%d+) (.-) Seed")
    if plantAmt and plantName then
        return {
            Type = "Plant",
            Amount = tonumber(plantAmt),
            Name = AI_NormalizeName(plantName)
        }
    end
    
    local harvestAmt, harvestName = string.match(text, "Harvest (%d+) (.+)")
    if harvestAmt and harvestName then
        return {
            Type = "Harvest",
            Amount = tonumber(harvestAmt),
            Name = AI_NormalizeName(harvestName)
        }
    end
    
    local sellAmt, sellName = string.match(text, "Sell (%d+) (.+)")
    if sellAmt and sellName then
        return {
            Type = "SellSpecific",
            Amount = tonumber(sellAmt),
            Name = AI_NormalizeName(sellName)
        }
    end

    local waterAmt, waterName = string.match(text, "Water (%d+) (.+)")
    if waterAmt and waterName then
        return {
            Type = "Water",
            Amount = tonumber(waterAmt),
            Name = AI_NormalizeName(waterName)
        }
    end

    local lowerText = string.lower(text)
    if string.find(lowerText, "earn") or string.find(lowerText, "shilling") or string.find(lowerText, "%$") or string.match(text, "%d+/%d+[KkMm]") then
        return {
            Type = "Money",
            Name = "ANY"
        }
    end
    
    return nil 
end

