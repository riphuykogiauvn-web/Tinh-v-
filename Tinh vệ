local function AI_NormalizeName(name)
    local n = string.lower(name)
    if string.find(n, "apples") then
        return "Apple"
    end
    if string.find(n, "onions") then
        return "Onion"
    end
    if string.find(n, "carrots") then
        return "Carrot"
    end
    if string.find(n, "corns") then
        return "Corn"
    end
    if string.find(n, "strawberries") then
        return "Strawberry"
    end
    if string.find(n, "mushrooms") then
        return "Mushroom"
    end
    if string.find(n, "tomatoes") then
        return "Tomato"
    end
    if string.find(n, "roses") then
        return "Rose"
    end
    if string.find(n, "cabbages") then
        return "Cabbage"
    end
    if string.find(n, "cherries") then
        return "Cherry"
    end
    if string.find(n, "potatoes") then
        return "Potato"
    end
    if string.find(n, "plums") then
        return "Plum"
    end
    if string.find(n, "bamboos") then
        return "Bamboo"
    end
    if string.find(n, "mangoes") or string.find(n, "mangos") then
        return "Mango"
    end
    if string.find(n, "crops") or string.find(n, "plants") then
        return "ANY"
    end 
    return (name:gsub("^%l", string.upper))
end

local function AI_SwitchQuestTab(keyword)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    local questGui = pGui and pGui:FindFirstChild("Quests")
    if not questGui then
        return false
    end
    
    for _, obj in pairs(questGui:GetDescendants()) do
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and obj.Visible then
            local text = string.lower(obj:IsA("TextButton") and obj.Text or "")
            if string.find(text, string.lower(keyword)) then
                AI_ForceClick(obj)
                return true
            end
            
