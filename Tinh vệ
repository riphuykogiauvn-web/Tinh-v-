local function AI_ExecutePlant(targetName, qNameText)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if not root or not hum then
        return false
    end

    local seedTool = nil
    local function isValidSeed(tool)
        if not tool:IsA("Tool") then
            return false
        end
        local lowerName = string.lower(tool.Name)
        
        if targetName == "ANY" then
            if string.find(lowerName, "seed") then
                return true
            end
            return false
        end
        
        if string.find(lowerName, string.lower(targetName)) and string.find(lowerName, "seed") then
            return true
        end
        return false
    end
    
    for _, t in pairs(char:GetChildren()) do
        if isValidSeed(t) then
            seedTool = t
            break
        end
    end
    
    if not seedTool then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, t in pairs(backpack:GetChildren()) do
                if isValidSeed(t) then
                    seedTool = t
                    break
                end
            end
        end
    end

    if not seedTool then
        if targetName == "ANY" then
            AI_UpdateStatus("📌 Nhiệm vụ: " .. qNameText .. "\n⚠️ Balo hết sạch hạt. Đang đi mua hạt Cà Rốt...")
            local bought = AI_GoBuySeed_Strict("Carrot") 
            if bought then
                task.wait(1)
            end
        else
            AI_UpdateStatus("📌 Nhiệm vụ: " .. qNameText .. "\n⚠️ Balo không có hạt " .. targetName .. ". Đang chờ mua hạt...")
            local bought = AI_GoBuySeed_Strict(targetName)
            if bought then
                task.wait(1)
            end
        end

        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, t in pairs(backpack:GetChildren()) do
                if isValidSeed(t) then
                    seedTool = t
                    break
                end
            end
        end
    end

    if not seedTool then
        return false
    end 

    local realSeedNameToPlant = targetName
    if targetName == "ANY" then
        realSeedNameToPlant = string.gsub(seedTool.Name, " Seed", "")
    end

    local dirtPartTarget = nil
    local plotsFolder = Workspace:FindFirstChild("Plots")
    
    if plotsFolder then
        for _, plot in pairs(plotsFolder:GetChildren()) do
            local pArea = plot:FindFirstChild("PlantableArea")
            if pArea then
                local isMyLand = false
                if string.find(string.lower(plot.Name), string.lower(LocalPlayer.Name)) then
                    isMyLand = true
                end
                
                if not isMyLand then
                    for _, obj in pairs(plot:GetDescendants()) do
                        if obj:IsA("ObjectValue") and obj.Value == LocalPlayer then
                            isMyLand = true
                            break
                        end
                        if obj:IsA("StringValue") and (obj.Value == LocalPlayer.Name or obj.Value == LocalPlayer.DisplayName) then
                            isMyLand = true
                            break
                        end
                    end
                end
                
                if isMyLand then
                    dirtPartTarget = pArea:FindFirstChildOfClass("BasePart") or pArea:FindFirstChildOfClass("Part")
                    if dirtPartTarget then
                        break
                    end
                end
            end
        end
    end

    if not dirtPartTarget then
        return false
    end

    AI_UpdateStatus("📌 Nhiệm vụ: " .. qNameText .. "\n🌱 Đang tự động gieo hạt " .. realSeedNameToPlant .. "...")
    
    local centerPos = dirtPartTarget.Position
    local scanRadius = 40 
    local PlantGridSpacing = 3.5 
    local plantedSuccess = false

    for i = -scanRadius, scanRadius, PlantGridSpacing do
        if plantedSuccess or not getgenv().SmartAIToggle then
            break
        end
        for j = -scanRadius, scanRadius, PlantGridSpacing do
            if not getgenv().SmartAIToggle then
                break
            end
            
            local rayOrigin = Vector3.new(centerPos.X + i, centerPos.Y + 50, centerPos.Z + j)
            local rayDirection = Vector3.new(0, -100, 0) 
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {char} 
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            
            local result = Workspace:Raycast(rayOrigin, rayDirection, rayParams)
            
            if result and result.Instance.Name == "Part" and result.Instance.Parent and result.Instance.Parent.Name == "PlantableArea" then
                local targetPos = result.Position
                
                if seedTool.Parent ~= char then
                    hum:EquipTool(seedTool)
                    task.wait(0.2)
                end
                
                root.Velocity = Vector3.zero
                root.RotVelocity = Vector3.zero
                root.CFrame = CFrame.new(targetPos + Vector3.new(0, 4, 0))
                task.wait(0.2) 
                
                pcall(function()
                    ReplicatedStorage.RemoteEvents.PlantSeed:InvokeServer(realSeedNameToPlant, targetPos)
                end)
                
                plantedSuccess = true
                break 
            end
        end
    end

    if not plantedSuccess then
        AI_UpdateStatus("📌 Nhiệm vụ: " .. qNameText .. "\n⚠️ Vườn sếp đã FULL 300 CÂY! Chờ nhổ bớt...")
        task.wait(3)
    end
    return plantedSuccess
end

